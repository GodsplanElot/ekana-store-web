# Canonical application origin used for Paystack callbacks and staff invitation links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_PINTEREST_URL=

# Public launch gate (Africa/Lagos is UTC+1)
LAUNCH_GATE_ENABLED=true
LAUNCH_AT=2026-07-12T00:00:00+01:00

# Supabase public configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Supabase server-only configuration
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY

# Direct Postgres access is only required for Drizzle or database tooling.
DATABASE_URL=

# Paystack hosted checkout is initialized on the server, so no public Paystack key is needed.
# Use a test secret locally and in preview; keep the live secret production-only.
PAYSTACK_CHECKOUT_ENABLED=false
PAYSTACK_SECRET_KEY=sk_test_REPLACE_ME

# Secures /api/cron/payment-maintenance. Use 32 random bytes encoded as 64 hex characters.
CRON_SECRET=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Required for independently retryable admin payment confirmation/review alerts.
ORDER_NOTIFICATION_EMAIL=
